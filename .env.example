# ── このファイルを .env.local にコピーして値を入れる（.env はGitに上げない）──
# Vercel では「Project ▸ Settings ▸ Environment Variables」に同じものを登録する。

# 記事の自動生成（Claude API）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# 記事自動生成Cronの保護（任意・推奨）
CRON_SECRET=

# サイト情報
SITE_URL=https://moneaglow.com
SITE_NAME=MONEA GLOW

# ドロップシッピング（使うプロバイダのキーだけ入れる）
DROPSHIP_PROVIDER=cjdropshipping
CJ_ACCESS_TOKEN=
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=
ALIEXPRESS_TRACKING_ID=
SPOCKET_API_KEY=
DSERS_API_TOKEN=
ZENDROP_API_KEY=

# Vercel KV（VercelでKVを接続すると自動で入る。ローカル検証時のみ手動設定）
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
